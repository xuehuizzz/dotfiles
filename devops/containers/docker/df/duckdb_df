# alias duckdb="docker run --rm -it -v \$(pwd):/data -w /data duckdb-cli:latest"

# syntax=docker/dockerfile:1
FROM debian:bookworm-slim

LABEL maintainer="xuehui <xuehuizzz103@gmail.com>" \
      version="2.0" \
      description="DuckDB CLI with pre-installed extensions for offline/air-gapped use"

ENV DUCKDB_DIR=/opt/duckdb \
    DEBIAN_FRONTEND=noninteractive

ENV DUCKDB_EXTENSION_DIRECTORY=${DUCKDB_DIR}/extensions \
    PATH="${DUCKDB_DIR}/bin:${PATH}"

# Docker BuildKit 自动注入 TARGETARCH（amd64 / arm64）
ARG TARGETARCH

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl unzip && \
    mkdir -p ${DUCKDB_DIR}/bin ${DUCKDB_EXTENSION_DIRECTORY} && \
    \
    # ---- 根据 TARGETARCH 映射 DuckDB 发布包的架构名 ----
    if [ "$TARGETARCH" = "arm64" ]; then \
      DUCKDB_ARCH="aarch64"; \
    else \
      DUCKDB_ARCH="amd64"; \
    fi && \
    echo ">>> Downloading latest DuckDB CLI for ${DUCKDB_ARCH} ..." && \
    curl -fsSL -o /tmp/duckdb.zip \
      "https://github.com/duckdb/duckdb/releases/latest/download/duckdb_cli-linux-${DUCKDB_ARCH}.zip" && \
    unzip /tmp/duckdb.zip -d /tmp && \
    mv /tmp/duckdb ${DUCKDB_DIR}/bin/duckdb && \
    chmod +x ${DUCKDB_DIR}/bin/duckdb && \
    \
    # ---- 确认安装成功，打印版本 ----
    echo ">>> Installed:" && duckdb --version && \
    \
    # ---- 构建阶段联网预装扩展，写入 DUCKDB_EXTENSION_DIRECTORY ----
    duckdb -c " \
      INSTALL excel;   \
      INSTALL json;    \
      INSTALL parquet; \
      INSTALL httpfs;  \
      INSTALL fts;     \
    " && \
    echo ">>> Extensions installed to ${DUCKDB_EXTENSION_DIRECTORY}" && \
    \
    # ---- 清理：删除仅构建时需要的包，缩减镜像体积 ----
    apt-get purge -y curl unzip && \
    apt-get autoremove -y && \
    rm -rf /tmp/* /var/lib/apt/lists/*

# ---- DuckDB 启动配置：关闭自动联网安装，开启自动加载已有扩展 ----
RUN printf '%s\n' \
      "SET autoinstall_known_extensions = false;" \
      "SET autoload_known_extensions  = true;" \
      > /root/.duckdbrc

ENTRYPOINT ["duckdb"]

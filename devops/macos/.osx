#!/usr/bin/env bash

# ============================================================================
#  macOS 系统偏好配置脚本
#  使用方法: bash ~/.osx
#  参考: https://macos-defaults.com
# ============================================================================

# 关闭所有正在运行的提示
osascript -e 'tell application "System Preferences" to quit'

# ============================================================================
#  一、系统通用 (NSGlobalDomain)
# ============================================================================

# 显示所有文件扩展名
defaults write NSGlobalDomain AppleShowAllExtensions -bool true

# 默认存储到本地磁盘，而不是 iCloud
defaults write NSGlobalDomain NSDocumentSaveNewDocumentsToCloud -bool false

# 关闭智能引号 (代码党救命)
defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false

# 关闭智能破折号
defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false

# 关闭自动拼写纠正
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false

# 关闭自动首字母大写
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false

# 关闭双击空格变句号 (按需，写文档保留可能更好)
defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false

# 启用按住按键重复 (默认是弹出特殊字符菜单)
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false

# 极速按键重复 (适合 Vim 党)
defaults write NSGlobalDomain KeyRepeat -int 2
defaults write NSGlobalDomain InitialKeyRepeat -int 15

# Tab 键聚焦所有控件 (对话框中可用 Tab 切换按钮)
defaults write NSGlobalDomain AppleKeyboardUIMode -int 3

# 滚动条仅在滚动时显示
# 可选值: WhenScrolling, Automatic, Always
defaults write NSGlobalDomain AppleShowScrollBars -string "WhenScrolling"

# ============================================================================
#  二、登录 & 启动
# ============================================================================

# 重启系统后不打开未关闭的软件
defaults write com.apple.loginwindow TALLogoutSavesState -bool false
defaults write com.apple.loginwindow LoginwindowLaunchesRelaunchApps -bool false

# 关闭崩溃报错弹窗
defaults write com.apple.CrashReporter DialogType none

# Apple Silicon: 打开盖子或连接电源时均不自动开机 (按需取消注释)
# sudo nvram BootPreference=%00

# ============================================================================
#  三、Dock
# ============================================================================

# 自动隐藏 Dock
defaults write com.apple.dock autohide -bool true

# 自动隐藏/显示动画时间设为 0 (立即响应)
defaults write com.apple.dock autohide-time-modifier -float 0

# 鼠标移到边缘后立即弹出 Dock (无延迟)
defaults write com.apple.dock autohide-delay -float 0

# 最小化窗口时归入应用图标 (而非单独占位)
defaults write com.apple.dock minimize-to-application -bool true

# 最小化效果: scale (缩放) / genie (神灯)
defaults write com.apple.dock mineffect -string "scale"

# 不显示"最近使用的应用"
defaults write com.apple.dock show-recents -bool false

# Dock 图标大小
defaults write com.apple.dock tilesize -int 42

# 隐藏的 App 在 Dock 中半透明显示
defaults write com.apple.dock showhidden -bool true

# 关闭 Dock 鼠标悬停放大 (按需)
# defaults write com.apple.dock magnification -bool false

# ============================================================================
#  四、Finder (访达)
# ============================================================================

# 文件夹始终排在最前
defaults write com.apple.finder _FXSortFoldersFirst -bool true

# 默认搜索当前文件夹 (而非整个 Mac)
# 可选: SCev (本机), SCcf (当前文件夹), SCsp (上次范围)
defaults write com.apple.finder FXDefaultSearchScope -string "SCcf"

# 修改文件扩展名时不弹警告
defaults write com.apple.finder FXEnableExtensionChangeWarning -bool false

# 显示路径栏
defaults write com.apple.finder ShowPathbar -bool true

# 显示状态栏
defaults write com.apple.finder ShowStatusBar -bool true

# 在标题栏显示完整 POSIX 路径
defaults write com.apple.finder _FXShowPosixPathInTitle -bool true

# 默认视图样式 (列表视图: Nlsv / 图标: icnv / 分栏: clmv / 画廊: glyv)
defaults write com.apple.finder FXPreferredViewStyle -string "Nlsv"

# 新建窗口默认打开 Downloads 目录
#   PfDe = Desktop (桌面)
#   PfHm = Home    (家目录)
#   PfDo = Documents (文稿)
#   PfCm = Computer (电脑)
#   PfAF = All My Files (所有我的文件)
#   PfLo = Other    (自定义路径，配合 NewWindowTargetPath 使用)
defaults write com.apple.finder NewWindowTarget -string "PfLo"
defaults write com.apple.finder NewWindowTargetPath -string "file://${HOME}/Downloads/"

# 显示外置磁盘 / 移动硬盘 / 光盘 / 服务器在桌面
defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool true
defaults write com.apple.finder ShowRemovableMediaOnDesktop -bool true
defaults write com.apple.finder ShowMountedServersOnDesktop -bool true
defaults write com.apple.finder ShowHardDrivesOnDesktop -bool false

# 不在网络共享和 U 盘上创建 .DS_Store
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true

# 30 天后自动清空废纸篓
defaults write com.apple.finder FXRemoveOldTrashItems -bool true

# ============================================================================
#  五、磁盘镜像 (DMG / Disk Images)
# ============================================================================

# 挂载 DMG 后的自动操作
# 可选值:
#   eject       - 卸载完成后直接推出镜像 (DMG 文件保留在原位)
#   trash       - 将 DMG 文件移到废纸篓
#   ask         - 弹窗询问用户
#   do-nothing  - 不做任何操作 (系统默认)
defaults write com.apple.frameworks.diskimages auto-action -string "eject"

# 跳过 DMG 校验 (加快挂载速度，可信来源时建议开启)
defaults write com.apple.frameworks.diskimages skip-verify -bool true
defaults write com.apple.frameworks.diskimages skip-verify-locked -bool true
defaults write com.apple.frameworks.diskimages skip-verify-remote -bool true

# 挂载 DMG 后不自动打开 Finder 窗口 (按需，部分用户喜欢自动打开)
# defaults write com.apple.frameworks.diskimages auto-open-ro-root -bool false
# defaults write com.apple.frameworks.diskimages auto-open-rw-root -bool false

# ============================================================================
#  六、截图
# ============================================================================

# 截图保存到 ~/Pictures/Screenshots
mkdir -p "${HOME}/Pictures/Screenshots"
defaults write com.apple.screencapture location -string "${HOME}/Pictures/Screenshots"

# 截图格式 (png / jpg / pdf / tiff)
defaults write com.apple.screencapture type -string "jpg"

# 关闭窗口截图阴影
defaults write com.apple.screencapture disable-shadow -bool true

# 文件名不带日期
defaults write com.apple.screencapture include-date -bool false

# 截图后右下角不显示缩略图
defaults write com.apple.screencapture show-thumbnail -bool false

# ============================================================================
#  七、Safari
# ============================================================================

# 显示完整 URL
defaults write com.apple.Safari ShowFullURLInSmartSearchField -bool true

# 启用开发菜单
defaults write com.apple.Safari IncludeDevelopMenu -bool true
defaults write com.apple.Safari WebKitDeveloperExtrasEnabledPreferenceKey -bool true
defaults write com.apple.Safari "com.apple.Safari.ContentPageGroupIdentifier.WebKit2DeveloperExtrasEnabled" -bool true

# 默认搜索引擎处不向 Apple 发送搜索建议查询
defaults write com.apple.Safari UniversalSearchEnabled -bool false
defaults write com.apple.Safari SuppressSearchSuggestions -bool true

# ============================================================================
#  八、TextEdit
# ============================================================================

# 默认使用纯文本模式
defaults write com.apple.TextEdit RichText -int 0

# 默认 UTF-8 编码
defaults write com.apple.TextEdit PlainTextEncoding -int 4
defaults write com.apple.TextEdit PlainTextEncodingForWrite -int 4

# ============================================================================
#  九、Terminal
# ============================================================================

# 焦点跟随鼠标
defaults write com.apple.Terminal FocusFollowsMouse -bool true

# 仅使用 UTF-8
defaults write com.apple.Terminal StringEncodings -array 4

# ============================================================================
#  十、Time Machine
# ============================================================================

# 不询问新硬盘是否用作备份盘
defaults write com.apple.TimeMachine DoNotOfferNewDisksForBackup -bool true

# ============================================================================
#  十一、Activity Monitor (活动监视器)
# ============================================================================

# Dock 图标显示 CPU 使用率
# 0=Application, 2=Network, 3=Disk, 5=CPU Usage, 6=CPU History
defaults write com.apple.ActivityMonitor IconType -int 5

# 默认显示所有进程
defaults write com.apple.ActivityMonitor ShowCategory -int 0

# 按 CPU 使用率排序
defaults write com.apple.ActivityMonitor SortColumn -string "CPUUsage"
defaults write com.apple.ActivityMonitor SortDirection -int 0

# ============================================================================
#  十二、Mission Control & 热区
# ============================================================================

# Mission Control 不自动重排空间
defaults write com.apple.dock mru-spaces -bool false

# 按应用分组窗口
defaults write com.apple.dock expose-group-apps -bool true

# ============================================================================
#  十三、图像捕捉
# ============================================================================

# 连接相机 / iPhone 时不自动打开图像捕捉
defaults -currentHost write com.apple.ImageCapture disableHotPlug -bool true

# ============================================================================
#  十四、安全 & 隐私
# ============================================================================

# 关闭从互联网下载文件的"打开警告" (轻度风险，按需)
# defaults write com.apple.LaunchServices LSQuarantine -bool false

# 立即在锁屏后要求密码
defaults write com.apple.screensaver askForPassword -int 1
defaults write com.apple.screensaver askForPasswordDelay -int 0

# ============================================================================
#  十五、Mac App Store
# ============================================================================

# 启用自动更新检查
defaults write com.apple.SoftwareUpdate AutomaticCheckEnabled -bool true

# 每天检查更新 (而非每周)
defaults write com.apple.SoftwareUpdate ScheduleFrequency -int 1

# 自动下载后台更新
defaults write com.apple.SoftwareUpdate AutomaticDownload -int 1

# ============================================================================
#  最后: 重启相关服务使设置生效
# ============================================================================

for app in "Activity Monitor" \
    "cfprefsd" \
    "Dock" \
    "Finder" \
    "SystemUIServer" \
    "Terminal"; do
    killall "${app}" &> /dev/null
done

echo "✅ 配置完成！部分设置可能需要重启或重新登录后才能生效。"

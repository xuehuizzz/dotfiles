# 以编辑模式 ( -e ) 打开全局 Git 配置文件
#   git config --global -e

# ── 用户信息 ─────────────────────────────────────────
[user]
  name = xuehui
  email = xuehuizzz103@gmail.com

# ── 初始化 ───────────────────────────────────────────
[init]
  defaultBranch = main

# ── 核心设置 ─────────────────────────────────────────
[core]
  excludesfile = ~/.gitignore_global
  quotepath = false

[commit]
  template = ~/.stCommitMsg

# ── 拉取 & 同步 ─────────────────────────────────────
[pull]
  rebase = true

[fetch]
  # git fetch 时自动清理远程已删除的分支引用
  prune = true

# ── 差异 & 追溯 ─────────────────────────────────────
[diff]
  # 比默认 myers 算法产生更可读的 diff
  algorithm = histogram

[blame]
  coloring = highlightRecent
  date = relative

# ── 冲突解决 ─────────────────────────────────────────
[rerere]
  # 记住冲突解决方式，rebase 工作流下非常有用
  enabled = true

# ── 网络 ─────────────────────────────────────────────
[http]
  sslVerify = true

# ── 别名 ─────────────────────────────────────────────
#
# Conventional Commits 规范:
#   格式: <type>(<scope>): <subject>
#
#   type        说明
#   ──────────  ──────────────────────────────
#   feat        新功能
#   fix         修复 Bug
#   docs        仅文档变更
#   style       代码格式调整（不影响逻辑）
#   refactor    重构（非新功能、非修 Bug）
#   perf        性能优化
#   test        添加或修改测试
#   build       构建系统或外部依赖变更
#   ci          CI/CD 配置变更
#   chore       其他杂项
#   revert      回退之前的提交
#
#   示例:
#     feat(auth): 添加微信扫码登录
#     fix(cart): 修复数量为 0 时仍可下单的问题
#     docs: 更新 README 部署说明
#     refactor(api): 将请求层从 axios 迁移到 fetch
#     chore: 删除废弃的配置文件
#
[alias]
  # 常用简写
  s = status
  co = checkout
  ci = commit
  br = branch

  # 撤销操作
  unadd = restore --staged
  # 撤销最近一次提交，保留修改内容在工作区
  uncommit = reset HEAD~1

  # 把当前分支推送到远程同名分支并设置跟踪关系
  # 初次 git done，之后直接 git push 即可
  done = !git push -u origin HEAD

  # 日志查看
  hist = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
  # 同 hist 但不分页
  lg = !git --no-pager log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
  # 同 lg 但显示所有分支
  lga = !git --no-pager log --all --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
  # 查看最近一周指定用户的提交，用法: git lgu xuehui
  lgu = "!f() { git log --all --pretty=format:'%h %cd %s (%an)' --since='7 days ago' --author=\"$1\"; }; f"

  # 底层调试
  type = cat-file -t
  dump = cat-file -p

  # 查看 commit type 速查表，用法: git types
  types = !printf '\\n  \\033[1mConventional Commits 速查表\\033[0m\\n  格式: <type>(<scope>): <subject>\\n\\n  \\033[33mfeat\\033[0m        新功能\\n  \\033[33mfix\\033[0m         修复 Bug\\n  \\033[33mdocs\\033[0m        仅文档变更\\n  \\033[33mstyle\\033[0m       代码格式调整（不影响逻辑）\\n  \\033[33mrefactor\\033[0m    重构（非新功能、非修 Bug）\\n  \\033[33mperf\\033[0m        性能优化\\n  \\033[33mtest\\033[0m        添加或修改测试\\n  \\033[33mbuild\\033[0m       构建系统或外部依赖变更\\n  \\033[33mci\\033[0m          CI/CD 配置变更\\n  \\033[33mchore\\033[0m       其他杂项\\n  \\033[33mrevert\\033[0m      回退之前的提交\\n\\n  \\033[1m示例:\\033[0m\\n  feat(auth): 添加微信扫码登录\\n  fix(cart): 修复数量为 0 时仍可下单的问题\\n  docs: 更新 README 部署说明\\n  refactor(api): 请求层从 axios 迁移到 fetch\\n  chore: 删除废弃的配置文件\\n'

# ── Git LFS ──────────────────────────────────────────
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

# ── 安全目录 (Homebrew) ─────────────────────────────
[safe]
  directory = /usr/local/Homebrew
  directory = /usr/local/Homebrew/Library/Taps/homebrew/homebrew-core
  directory = /usr/local/Homebrew/Library/Taps/homebrew/homebrew-cask

# 先创建文件夹
# mkdir -p ~/.ssh/sockets
# chmod 700 ~/.ssh/sockets

Host *
    # 连接稳定性增强
    ServerAliveInterval 60
    ServerAliveCountMax 3
    TCPKeepAlive yes              # 系统 TCP 层保活,与 ServerAlive 双保险

    # DNS / 解析加速
    UseDNS no                     # 避免 SSH server 反查 DNS 卡顿(注:此项实际写在 sshd_config,客户端可忽略)
    AddressFamily inet            # 强制 IPv4,避免 IPv6 解析慢

    # 连接复用(显著提速)
    ControlMaster auto
    ControlPersist 10m
    ControlPath ~/.ssh/sockets/%r@%h-%p

    # 默认身份文件(省去 -i 参数)
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes            # 只用指定的 key,避免 agent 把所有 key 都试一遍

    # 密钥管理
    AddKeysToAgent yes
    # UseKeychain yes             # macOS 用户取消注释

    # 更现代的安全默认
    PubkeyAuthentication yes
    PasswordAuthentication no
    KbdInteractiveAuthentication no
    HashKnownHosts yes

    # 防假死连接
    ExitOnForwardFailure yes      # 端口转发失败直接退出

    # Debug & 可观测性
    LogLevel ERROR                # 默认更干净;调试时改 DEBUG

    # 传输优化(按需)
    Compression yes



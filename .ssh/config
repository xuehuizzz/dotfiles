# 先创建文件夹
# mkdir -p ~/.ssh/sockets
# chmod 700 ~/.ssh/sockets

Host *
    # === 连接复用(显著提速)===
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

    # === 保持连接活跃 ===
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # === 密钥管理 ===
    AddKeysToAgent yes
    # UseKeychain yes        # macOS 取消注释

    # === 安全性 ===
    HashKnownHosts yes    # 把 ~/.ssh/known_hosts 里的主机名/IP 哈希存储,而不是明文

    # === 传输优化(按需)===
    Compression yes
